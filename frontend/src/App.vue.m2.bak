<template>
  <!-- Banner de entorno de desarrollo (visible solo en ENV=development) -->
  <div
    v-if="isDev"
    class="bg-red-600 text-white text-center text-sm font-bold py-1 fixed top-0 left-0 right-0 z-50"
  >
    ENTORNO DE DESARROLLO
  </div>

  <div :class="{ 'pt-7': isDev }">
    <router-view />
  </div>
</template>

<script setup>
// El backend expone /api/v1/config/env que devuelve el entorno actual.
// Mientras no exista el endpoint (M3), asumimos desarrollo si la URL es localhost.
import { ref } from 'vue'

const isDev = ref(
  window.location.hostname === 'localhost' ||
  window.location.hostname === '127.0.0.1'
)
</script>
